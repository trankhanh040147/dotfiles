// transaction: BeginTx, Rollback/Commit.
// Cần: export DATABASE_URL="postgres://..."
// Chạy: go run transaction.go
package main

import (
	"context"
	"database/sql"
	"fmt"
	"os"

	_ "github.com/lib/pq"
)

func main() {
	dsn := os.Getenv("DATABASE_URL")
	if dsn == "" {
		fmt.Println("DATABASE_URL not set")
		return
	}
	db, err := sql.Open("postgres", dsn)
	if err != nil {
		fmt.Println("open:", err)
		return
	}
	defer db.Close()
	if err := db.Ping(); err != nil {
		fmt.Println("ping:", err)
		return
	}

	ctx := context.Background()
	tx, err := db.BeginTx(ctx, nil)
	if err != nil {
		fmt.Println("begintx:", err)
		return
	}
	defer tx.Rollback()

	_, err = tx.Exec("CREATE TEMP TABLE IF NOT EXISTS accounts (id SERIAL PRIMARY KEY, balance INT)")
	if err != nil {
		fmt.Println("create:", err)
		return
	}
	_, err = tx.Exec("INSERT INTO accounts (balance) VALUES (100), (200)")
	if err != nil {
		fmt.Println("insert:", err)
		return
	}
	_, err = tx.Exec("UPDATE accounts SET balance = balance - 10 WHERE id = 1")
	if err != nil {
		fmt.Println("update:", err)
		return
	}
	_, err = tx.Exec("UPDATE accounts SET balance = balance + 10 WHERE id = 2")
	if err != nil {
		fmt.Println("update:", err)
		return
	}
	if err := tx.Commit(); err != nil {
		fmt.Println("commit:", err)
		return
	}
	fmt.Println("transaction committed")
}

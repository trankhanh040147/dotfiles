// Context timeout + select: gọi hàm chậm trong goroutine, select giữa result và ctx.Done().
// Chạy: go run context_timeout.go
package main

import (
	"context"
	"fmt"
	"time"
)

func slowWork() string {
	time.Sleep(3 * time.Second)
	return "done"
}

func main() {
	ctx, cancel := context.WithTimeout(context.Background(), 2*time.Second)
	defer cancel()

	resultCh := make(chan string)
	go func() {
		resultCh <- slowWork()
	}()

	select {
	case r := <-resultCh:
		fmt.Println(r)
	case <-ctx.Done():
		fmt.Println("timeout:", ctx.Err())
	}
}

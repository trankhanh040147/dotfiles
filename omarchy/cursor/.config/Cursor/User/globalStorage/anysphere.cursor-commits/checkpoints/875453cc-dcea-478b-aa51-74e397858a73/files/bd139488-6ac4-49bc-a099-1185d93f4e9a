package transport

import (
	"context"
	"encoding/json"
	"errors"
	"log"
	"net/http"
	"strconv"
	"strings"
	"sync"
	"time"

	"chatmessaging/internal/core"

	"github.com/go-redis/redis/v8"
	"github.com/google/uuid"
	"github.com/gorilla/websocket"
)

type GatewayHandler struct {
	core              *core.Service
	redis             *redis.Client
	gatewayID         string
	presenceTTL       time.Duration
	heartbeatInterval time.Duration
	globalEventStream string
	streamReadBlock   time.Duration

	sessionsMu sync.RWMutex
	sessions   map[uuid.UUID]map[string]*gatewaySession

	streamCursorMu sync.Mutex
	streamCursor   string
}

type gatewaySession struct {
	userID   uuid.UUID
	deviceID string
	conn     *websocket.Conn
	send     chan map[string]any
}

func NewGatewayHandler(
	coreSvc *core.Service,
	redisClient *redis.Client,
	gatewayID string,
	presenceTTL time.Duration,
	heartbeatInterval time.Duration,
	globalEventStream string,
	streamReadBlock time.Duration,
) *GatewayHandler {
	return &GatewayHandler{
		core:              coreSvc,
		redis:             redisClient,
		gatewayID:         gatewayID,
		presenceTTL:       presenceTTL,
		heartbeatInterval: heartbeatInterval,
		globalEventStream: globalEventStream,
		streamReadBlock:   streamReadBlock,
		sessions:          make(map[uuid.UUID]map[string]*gatewaySession),
		streamCursor:      "$",
	}
}

var upgrader = websocket.Upgrader{
	ReadBufferSize:  4096,
	WriteBufferSize: 4096,
	CheckOrigin: func(_ *http.Request) bool {
		return true
	},
}

type wsEnvelope struct {
	Type    string          `json:"type"`
	Payload json.RawMessage `json:"payload"`
}

type sendMessagePayload struct {
	ConversationID  uuid.UUID       `json:"conversation_id"`
	ClientMessageID string          `json:"client_message_id"`
	MessageType     string          `json:"message_type"`
	Body            json.RawMessage `json:"body"`
}

type deliveryAckPayload struct {
	MessageID uuid.UUID `json:"message_id"`
}

type readAckPayload struct {
	ConversationID    uuid.UUID `json:"conversation_id"`
	LastReadMessageID uuid.UUID `json:"last_read_message_id"`
}

func (h *GatewayHandler) HandleWS(w http.ResponseWriter, r *http.Request) {
	conn, err := upgrader.Upgrade(w, r, nil)
	if err != nil {
		http.Error(w, "upgrade failed", http.StatusBadRequest)
		return
	}
	defer conn.Close()

	userID, err := uuid.Parse(r.URL.Query().Get("user_id"))
	if err != nil {
		_ = conn.WriteJSON(map[string]any{
			"type":  "error",
			"error": "invalid user_id",
		})
		return
	}
	deviceID := r.URL.Query().Get("device_id")
	if deviceID == "" {
		deviceID = "default-device"
	}
	session := &gatewaySession{
		userID:   userID,
		deviceID: deviceID,
		conn:     conn,
		send:     make(chan map[string]any, 64),
	}
	h.registerSession(session)
	if err := h.setOnline(r.Context(), userID, deviceID); err != nil {
		log.Printf("set online failed for user=%s device=%s: %v", userID, deviceID, err)
	}
	defer func() {
		h.unregisterSession(session)
		if err := h.setOffline(context.Background(), userID, deviceID); err != nil {
			log.Printf("set offline failed for user=%s device=%s: %v", userID, deviceID, err)
		}
		close(session.send)
	}()

	go h.writeLoop(session)

	for {
		_ = conn.SetReadDeadline(time.Now().Add(h.presenceTTL))
		_, raw, err := conn.ReadMessage()
		if err != nil {
			return
		}

		var env wsEnvelope
		if err := json.Unmarshal(raw, &env); err != nil {
			_ = conn.WriteJSON(map[string]any{"type": "error", "error": "invalid json"})
			continue
		}

		switch env.Type {
		case "heartbeat":
			if err := h.refreshPresence(context.Background(), userID, deviceID); err != nil {
				log.Printf("refresh presence failed for user=%s device=%s: %v", userID, deviceID, err)
			}
			h.enqueue(session, map[string]any{
				"type": "heartbeat_ack",
				"ts":   time.Now().UTC(),
			})
		case "send_message":
			var p sendMessagePayload
			if err := json.Unmarshal(env.Payload, &p); err != nil {
				h.enqueue(session, map[string]any{"type": "error", "error": "invalid send payload"})
				continue
			}
			msg, duplicated, err := h.core.CreateMessage(context.Background(), core.CreateMessageInput{
				ConversationID:  p.ConversationID,
				SenderID:        userID,
				ClientMessageID: p.ClientMessageID,
				Type:            p.MessageType,
				Body:            p.Body,
			})
			if err != nil {
				log.Printf("create message failed: %v", err)
				h.enqueue(session, map[string]any{"type": "error", "error": "create message failed"})
				continue
			}
			h.enqueue(session, map[string]any{
				"type": "server_ack",
				"payload": map[string]any{
					"message_id":        msg.ID,
					"conversation_id":   msg.ConversationID,
					"sequence":          msg.Sequence,
					"created_at":        msg.CreatedAt,
					"duplicated_submit": duplicated,
				},
			})
		case "ack_delivery":
			var p deliveryAckPayload
			if err := json.Unmarshal(env.Payload, &p); err != nil {
				h.enqueue(session, map[string]any{"type": "error", "error": "invalid delivery ack payload"})
				continue
			}
			result, err := h.core.RecordDeliveryAck(context.Background(), core.DeliveryAckInput{
				MessageID: p.MessageID,
				UserID:    userID,
				DeviceID:  deviceID,
			})
			if err != nil {
				log.Printf("delivery ack failed: %v", err)
				h.enqueue(session, map[string]any{"type": "error", "error": "delivery ack failed"})
				continue
			}
			h.enqueue(session, map[string]any{
				"type": "delivery_ack_ok",
				"payload": map[string]any{
					"message_id":      result.MessageID,
					"conversation_id": result.ConversationID,
					"duplicate":       result.Duplicate,
				},
			})
		case "ack_read":
			var p readAckPayload
			if err := json.Unmarshal(env.Payload, &p); err != nil {
				h.enqueue(session, map[string]any{"type": "error", "error": "invalid read ack payload"})
				continue
			}
			result, err := h.core.RecordReadAck(context.Background(), core.ReadAckInput{
				ConversationID:    p.ConversationID,
				UserID:            userID,
				DeviceID:          deviceID,
				LastReadMessageID: p.LastReadMessageID,
			})
			if err != nil {
				log.Printf("read ack failed: %v", err)
				h.enqueue(session, map[string]any{"type": "error", "error": "read ack failed"})
				continue
			}
			h.enqueue(session, map[string]any{
				"type": "read_ack_ok",
				"payload": map[string]any{
					"conversation_id":        result.ConversationID,
					"last_read_message_id":   result.LastReadMessageID,
					"advanced_read_pointer":  result.AdvancedReadPointer,
					"duplicate_read_receipt": result.DuplicateReadReceipt,
				},
			})
		default:
			h.enqueue(session, map[string]any{"type": "error", "error": "unsupported event"})
		}
	}
}

func (h *GatewayHandler) StartEventLoop(ctx context.Context) {
	go func() {
		for {
			select {
			case <-ctx.Done():
				return
			default:
			}

			streamCursor := h.getStreamCursor()
			result, err := h.redis.XRead(ctx, &redis.XReadArgs{
				Streams: []string{h.globalEventStream, streamCursor},
				Count:   200,
				Block:   h.streamReadBlock,
			}).Result()
			if err != nil {
				if errors.Is(err, redis.Nil) {
					continue
				}
				if ctx.Err() != nil {
					return
				}
				log.Printf("gateway stream read failed: %v", err)
				continue
			}

			for _, stream := range result {
				for _, msg := range stream.Messages {
					h.setStreamCursor(msg.ID)
					if err := h.handleStreamMessage(ctx, msg.Values); err != nil {
						log.Printf("handle stream message failed: %v", err)
					}
				}
			}
		}
	}()
}

func (h *GatewayHandler) handleStreamMessage(ctx context.Context, values map[string]any) error {
	eventType := asString(values["event_type"])
	payloadRaw := asString(values["payload"])
	if eventType == "" || payloadRaw == "" {
		return nil
	}

	switch eventType {
	case "message.created":
		var msg core.Message
		if err := json.Unmarshal([]byte(payloadRaw), &msg); err != nil {
			return err
		}
		memberIDs, err := h.core.ListConversationMemberIDs(ctx, msg.ConversationID)
		if err != nil {
			return err
		}
		for _, userID := range memberIDs {
			if userID == msg.SenderID {
				continue
			}
			h.emitToUser(ctx, userID, map[string]any{
				"type":    "message_created",
				"payload": msg,
			})
		}
	case "message.delivery_ack", "message.read_ack":
		var payload map[string]any
		if err := json.Unmarshal([]byte(payloadRaw), &payload); err != nil {
			return err
		}
		conversationID, err := parseUUIDFromAny(payload["conversation_id"])
		if err != nil {
			return nil
		}
		actorID, _ := parseUUIDFromAny(payload["user_id"])
		memberIDs, err := h.core.ListConversationMemberIDs(ctx, conversationID)
		if err != nil {
			return err
		}

		updateType := "delivery_update"
		if eventType == "message.read_ack" {
			updateType = "read_update"
		}
		for _, userID := range memberIDs {
			if actorID != uuid.Nil && userID == actorID {
				continue
			}
			h.emitToUser(ctx, userID, map[string]any{
				"type":    updateType,
				"payload": payload,
			})
		}
	}
	return nil
}

func (h *GatewayHandler) emitToUser(ctx context.Context, userID uuid.UUID, envelope map[string]any) {
	h.sessionsMu.RLock()
	userSessions, ok := h.sessions[userID]
	if !ok {
		h.sessionsMu.RUnlock()
		return
	}
	targets := make([]*gatewaySession, 0, len(userSessions))
	for _, s := range userSessions {
		targets = append(targets, s)
	}
	h.sessionsMu.RUnlock()

	for _, session := range targets {
		owned, err := h.isOwnedByCurrentGateway(ctx, session.userID, session.deviceID)
		if err != nil {
			log.Printf("check owned session failed: %v", err)
			continue
		}
		if !owned {
			continue
		}
		h.enqueue(session, envelope)
	}
}

func (h *GatewayHandler) registerSession(s *gatewaySession) {
	h.sessionsMu.Lock()
	defer h.sessionsMu.Unlock()
	if _, ok := h.sessions[s.userID]; !ok {
		h.sessions[s.userID] = make(map[string]*gatewaySession)
	}
	h.sessions[s.userID][s.deviceID] = s
}

func (h *GatewayHandler) unregisterSession(s *gatewaySession) {
	h.sessionsMu.Lock()
	defer h.sessionsMu.Unlock()
	userSessions, ok := h.sessions[s.userID]
	if !ok {
		return
	}
	delete(userSessions, s.deviceID)
	if len(userSessions) == 0 {
		delete(h.sessions, s.userID)
	}
}

func (h *GatewayHandler) writeLoop(s *gatewaySession) {
	for msg := range s.send {
		_ = s.conn.SetWriteDeadline(time.Now().Add(5 * time.Second))
		if err := s.conn.WriteJSON(msg); err != nil {
			return
		}
	}
}

func (h *GatewayHandler) enqueue(s *gatewaySession, msg map[string]any) {
	select {
	case s.send <- msg:
	default:
		log.Printf("dropping ws message due to full send queue user=%s device=%s", s.userID, s.deviceID)
	}
}

func (h *GatewayHandler) setOnline(ctx context.Context, userID uuid.UUID, deviceID string) error {
	return h.redis.Set(ctx, presenceKey(userID, deviceID), h.gatewayID, h.presenceTTL).Err()
}

func (h *GatewayHandler) refreshPresence(ctx context.Context, userID uuid.UUID, deviceID string) error {
	return h.redis.Set(ctx, presenceKey(userID, deviceID), h.gatewayID, h.presenceTTL).Err()
}

func (h *GatewayHandler) setOffline(ctx context.Context, userID uuid.UUID, deviceID string) error {
	pipe := h.redis.TxPipeline()
	pipe.Del(ctx, presenceKey(userID, deviceID))
	pipe.Set(ctx, lastSeenKey(userID, deviceID), strconv.FormatInt(time.Now().UTC().Unix(), 10), 0)
	_, err := pipe.Exec(ctx)
	return err
}

func (h *GatewayHandler) isOwnedByCurrentGateway(ctx context.Context, userID uuid.UUID, deviceID string) (bool, error) {
	v, err := h.redis.Get(ctx, presenceKey(userID, deviceID)).Result()
	if err != nil {
		if errors.Is(err, redis.Nil) {
			return false, nil
		}
		return false, err
	}
	return v == h.gatewayID, nil
}

func (h *GatewayHandler) getStreamCursor() string {
	h.streamCursorMu.Lock()
	defer h.streamCursorMu.Unlock()
	return h.streamCursor
}

func (h *GatewayHandler) setStreamCursor(cursor string) {
	h.streamCursorMu.Lock()
	defer h.streamCursorMu.Unlock()
	h.streamCursor = cursor
}

func presenceKey(userID uuid.UUID, deviceID string) string {
	return "presence:" + userID.String() + ":" + deviceID
}

func lastSeenKey(userID uuid.UUID, deviceID string) string {
	return "presence:last_seen:" + userID.String() + ":" + deviceID
}

func asString(v any) string {
	switch t := v.(type) {
	case string:
		return t
	case []byte:
		return string(t)
	default:
		return ""
	}
}

func parseUUIDFromAny(v any) (uuid.UUID, error) {
	raw := strings.TrimSpace(asString(v))
	if raw == "" {
		return uuid.Nil, errors.New("uuid is empty")
	}
	return uuid.Parse(raw)
}

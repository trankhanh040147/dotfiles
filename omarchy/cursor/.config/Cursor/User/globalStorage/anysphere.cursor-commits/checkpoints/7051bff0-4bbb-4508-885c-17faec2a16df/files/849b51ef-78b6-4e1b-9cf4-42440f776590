package config

import (
	"fmt"
	"os"
	"strconv"
	"time"
)

type Config struct {
	ServiceName string
	HTTPAddr    string

	PostgresURL string
	RedisAddr   string
	RedisDB     int

	HeartbeatInterval time.Duration
	PresenceTTL       time.Duration

	OutboxPollInterval time.Duration
	OutboxBatchSize    int
}

func Load(serviceName string) (Config, error) {
	cfg := Config{
		ServiceName:       serviceName,
		HTTPAddr:          envOrDefault("HTTP_ADDR", ":8080"),
		PostgresURL:       envOrDefault("POSTGRES_URL", "postgres://chat:chat@localhost:5432/chat?sslmode=disable"),
		RedisAddr:         envOrDefault("REDIS_ADDR", "localhost:6379"),
		RedisDB:           intOrDefault("REDIS_DB", 0),
		HeartbeatInterval: durationOrDefault("HEARTBEAT_INTERVAL", 30*time.Second),
		PresenceTTL:       durationOrDefault("PRESENCE_TTL", 75*time.Second),
		OutboxPollInterval: durationOrDefault(
			"OUTBOX_POLL_INTERVAL",
			500*time.Millisecond,
		),
		OutboxBatchSize: intOrDefault("OUTBOX_BATCH_SIZE", 200),
	}

	if cfg.OutboxBatchSize <= 0 {
		return Config{}, fmt.Errorf("OUTBOX_BATCH_SIZE must be > 0")
	}
	if cfg.PresenceTTL <= cfg.HeartbeatInterval {
		return Config{}, fmt.Errorf("PRESENCE_TTL must be greater than HEARTBEAT_INTERVAL")
	}
	return cfg, nil
}

func envOrDefault(key, fallback string) string {
	v := os.Getenv(key)
	if v == "" {
		return fallback
	}
	return v
}

func intOrDefault(key string, fallback int) int {
	v := os.Getenv(key)
	if v == "" {
		return fallback
	}
	n, err := strconv.Atoi(v)
	if err != nil {
		return fallback
	}
	return n
}

func durationOrDefault(key string, fallback time.Duration) time.Duration {
	v := os.Getenv(key)
	if v == "" {
		return fallback
	}
	d, err := time.ParseDuration(v)
	if err != nil {
		return fallback
	}
	return d
}

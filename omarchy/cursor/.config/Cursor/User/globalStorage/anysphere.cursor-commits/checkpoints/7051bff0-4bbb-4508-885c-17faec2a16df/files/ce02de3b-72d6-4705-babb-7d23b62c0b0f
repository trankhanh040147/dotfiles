SHELL := /bin/bash

POSTGRES_URL ?= postgres://chat:chat@localhost:5432/chat?sslmode=disable
REDIS_ADDR ?= localhost:6379
REDIS_DB ?= 0

API_HTTP_ADDR ?= :18080
GATEWAY_HTTP_ADDR ?= :18081
OUTBOX_POLL_INTERVAL ?= 500ms
OUTBOX_BATCH_SIZE ?= 200

.PHONY: deps
deps:
	go mod tidy

.PHONY: infra-up
infra-up:
	docker compose up -d postgres redis

.PHONY: infra-down
infra-down:
	docker compose down

.PHONY: migrate
migrate:
	POSTGRES_URL="$(POSTGRES_URL)" go run ./cmd/migrate

.PHONY: run-api
run-api:
	HTTP_ADDR="$(API_HTTP_ADDR)" POSTGRES_URL="$(POSTGRES_URL)" go run ./cmd/api

.PHONY: run-gateway
run-gateway:
	HTTP_ADDR="$(GATEWAY_HTTP_ADDR)" POSTGRES_URL="$(POSTGRES_URL)" go run ./cmd/gateway

.PHONY: run-worker
run-worker:
	POSTGRES_URL="$(POSTGRES_URL)" REDIS_ADDR="$(REDIS_ADDR)" REDIS_DB="$(REDIS_DB)" OUTBOX_POLL_INTERVAL="$(OUTBOX_POLL_INTERVAL)" OUTBOX_BATCH_SIZE="$(OUTBOX_BATCH_SIZE)" go run ./cmd/worker

.PHONY: test
test:
	go test ./...

.PHONY: build
build:
	go build ./cmd/api ./cmd/gateway ./cmd/worker ./cmd/migrate

.PHONY: dev
dev:
	@echo "Run these in separate terminals:"
	@echo "  make run-worker"
	@echo "  make run-api"
	@echo "  make run-gateway"

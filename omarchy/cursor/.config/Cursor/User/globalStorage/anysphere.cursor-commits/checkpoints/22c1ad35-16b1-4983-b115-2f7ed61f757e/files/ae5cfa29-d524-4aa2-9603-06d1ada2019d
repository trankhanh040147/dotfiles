// Worker pool — N worker đọc từ channel jobs, main gửi job rồi close.
// Chạy: go run worker_pool.go
package main

import (
	"fmt"
	"sync"
)

func main() {
	const numWorkers = 3
	jobs := make(chan int, 10)
	var wg sync.WaitGroup

	for w := 0; w < numWorkers; w++ {
		wg.Add(1)
		go func(id int) {
			defer wg.Done()
			for j := range jobs {
				fmt.Printf("worker %d: job %d\n", id, j)
			}
		}(w)
	}

	for j := 1; j <= 5; j++ {
		jobs <- j
	}
	close(jobs)
	wg.Wait()
}

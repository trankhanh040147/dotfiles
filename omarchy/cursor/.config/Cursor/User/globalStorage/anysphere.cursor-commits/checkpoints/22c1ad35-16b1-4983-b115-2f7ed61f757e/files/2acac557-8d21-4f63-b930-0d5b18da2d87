// Bật pprof qua HTTP tại :6060.
// Chạy: go run pprof_http.go
// Sau đó: go tool pprof -http=:8080 http://localhost:6060/debug/pprof/profile?seconds=5
//         hoặc: curl http://localhost:6060/debug/pprof/heap
package main

import (
	"log"
	"net/http"
	_ "net/http/pprof"
	"time"
)

func main() {
	go func() {
		log.Println(http.ListenAndServe("localhost:6060", nil))
	}()
	for i := 0; i < 100; i++ {
		time.Sleep(100 * time.Millisecond)
	}
}

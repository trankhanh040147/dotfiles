// errgroup: nhiều goroutine, lỗi đầu tiên hủy context, Wait trả lỗi.
// Chạy: go run errgroup_demo.go
package main

import (
	"context"
	"fmt"
	"time"

	"golang.org/x/sync/errgroup"
)

func main() {
	g, ctx := errgroup.WithContext(context.Background())
	g.Go(func() error {
		time.Sleep(50 * time.Millisecond)
		return nil
	})
	g.Go(func() error {
		time.Sleep(50 * time.Millisecond)
		return nil
	})
	if err := g.Wait(); err != nil {
		fmt.Println("err:", err)
	} else {
		fmt.Println("ok")
	}
	_ = ctx
}

// Echo gRPC client: gọi Echo (unary) và StreamEcho (server stream).
// Chạy từ repo root: go run ./03_grpc/examples/client/
// (Chạy server trước: go run ./03_grpc/examples/server/)
package main

import (
	"context"
	"io"
	"log"
	"time"

	echov1 "example.com/leetcode/custom/03_grpc/examples/echo/v1"
	"google.golang.org/grpc"
	"google.golang.org/grpc/credentials/insecure"
)

func main() {
	conn, err := grpc.NewClient("localhost:50051", grpc.WithTransportCredentials(insecure.NewCredentials()))
	if err != nil {
		log.Fatal(err)
	}
	defer conn.Close()
	client := echov1.NewEchoServiceClient(conn)

	ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
	defer cancel()

	// Unary
	resp, err := client.Echo(ctx, &echov1.EchoRequest{Message: "hi"})
	if err != nil {
		log.Fatal(err)
	}
	log.Println("Echo:", resp.Message)

	// Server stream
	stream, err := client.StreamEcho(ctx, &echov1.EchoRequest{Message: "stream"})
	if err != nil {
		log.Fatal(err)
	}
	for {
		msg, err := stream.Recv()
		if err == io.EOF {
			break
		}
		if err != nil {
			log.Fatal(err)
		}
		log.Println("StreamEcho:", msg.Message)
	}
}

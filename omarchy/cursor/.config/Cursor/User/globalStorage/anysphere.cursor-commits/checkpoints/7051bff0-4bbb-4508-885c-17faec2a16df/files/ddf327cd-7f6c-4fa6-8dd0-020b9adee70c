package transport

import (
	"context"
	"encoding/json"
	"log"
	"net/http"
	"time"

	"chatmessaging/internal/core"

	"github.com/google/uuid"
	"github.com/gorilla/websocket"
)

type GatewayHandler struct {
	core *core.Service
}

func NewGatewayHandler(coreSvc *core.Service) *GatewayHandler {
	return &GatewayHandler{core: coreSvc}
}

var upgrader = websocket.Upgrader{
	ReadBufferSize:  4096,
	WriteBufferSize: 4096,
	CheckOrigin: func(_ *http.Request) bool {
		return true
	},
}

type wsEnvelope struct {
	Type    string          `json:"type"`
	Payload json.RawMessage `json:"payload"`
}

type sendMessagePayload struct {
	ConversationID  uuid.UUID       `json:"conversation_id"`
	ClientMessageID string          `json:"client_message_id"`
	MessageType     string          `json:"message_type"`
	Body            json.RawMessage `json:"body"`
}

type deliveryAckPayload struct {
	MessageID uuid.UUID `json:"message_id"`
}

type readAckPayload struct {
	ConversationID    uuid.UUID `json:"conversation_id"`
	LastReadMessageID uuid.UUID `json:"last_read_message_id"`
}

func (h *GatewayHandler) HandleWS(w http.ResponseWriter, r *http.Request) {
	conn, err := upgrader.Upgrade(w, r, nil)
	if err != nil {
		http.Error(w, "upgrade failed", http.StatusBadRequest)
		return
	}
	defer conn.Close()

	userID, err := uuid.Parse(r.URL.Query().Get("user_id"))
	if err != nil {
		_ = conn.WriteJSON(map[string]any{
			"type":  "error",
			"error": "invalid user_id",
		})
		return
	}
	deviceID := r.URL.Query().Get("device_id")
	if deviceID == "" {
		deviceID = "default-device"
	}

	for {
		_ = conn.SetReadDeadline(time.Now().Add(70 * time.Second))
		_, raw, err := conn.ReadMessage()
		if err != nil {
			return
		}

		var env wsEnvelope
		if err := json.Unmarshal(raw, &env); err != nil {
			_ = conn.WriteJSON(map[string]any{"type": "error", "error": "invalid json"})
			continue
		}

		switch env.Type {
		case "heartbeat":
			_ = conn.WriteJSON(map[string]any{
				"type": "heartbeat_ack",
				"ts":   time.Now().UTC(),
			})
		case "send_message":
			var p sendMessagePayload
			if err := json.Unmarshal(env.Payload, &p); err != nil {
				_ = conn.WriteJSON(map[string]any{"type": "error", "error": "invalid send payload"})
				continue
			}
			msg, duplicated, err := h.core.CreateMessage(context.Background(), core.CreateMessageInput{
				ConversationID:  p.ConversationID,
				SenderID:        userID,
				ClientMessageID: p.ClientMessageID,
				Type:            p.MessageType,
				Body:            p.Body,
			})
			if err != nil {
				log.Printf("create message failed: %v", err)
				_ = conn.WriteJSON(map[string]any{"type": "error", "error": "create message failed"})
				continue
			}
			_ = conn.WriteJSON(map[string]any{
				"type": "server_ack",
				"payload": map[string]any{
					"message_id":        msg.ID,
					"conversation_id":   msg.ConversationID,
					"sequence":          msg.Sequence,
					"created_at":        msg.CreatedAt,
					"duplicated_submit": duplicated,
				},
			})
		case "ack_delivery":
			var p deliveryAckPayload
			if err := json.Unmarshal(env.Payload, &p); err != nil {
				_ = conn.WriteJSON(map[string]any{"type": "error", "error": "invalid delivery ack payload"})
				continue
			}
			result, err := h.core.RecordDeliveryAck(context.Background(), core.DeliveryAckInput{
				MessageID: p.MessageID,
				UserID:    userID,
				DeviceID:  deviceID,
			})
			if err != nil {
				log.Printf("delivery ack failed: %v", err)
				_ = conn.WriteJSON(map[string]any{"type": "error", "error": "delivery ack failed"})
				continue
			}
			_ = conn.WriteJSON(map[string]any{
				"type": "delivery_ack_ok",
				"payload": map[string]any{
					"message_id":      result.MessageID,
					"conversation_id": result.ConversationID,
					"duplicate":       result.Duplicate,
				},
			})
		case "ack_read":
			var p readAckPayload
			if err := json.Unmarshal(env.Payload, &p); err != nil {
				_ = conn.WriteJSON(map[string]any{"type": "error", "error": "invalid read ack payload"})
				continue
			}
			result, err := h.core.RecordReadAck(context.Background(), core.ReadAckInput{
				ConversationID:    p.ConversationID,
				UserID:            userID,
				DeviceID:          deviceID,
				LastReadMessageID: p.LastReadMessageID,
			})
			if err != nil {
				log.Printf("read ack failed: %v", err)
				_ = conn.WriteJSON(map[string]any{"type": "error", "error": "read ack failed"})
				continue
			}
			_ = conn.WriteJSON(map[string]any{
				"type": "read_ack_ok",
				"payload": map[string]any{
					"conversation_id":        result.ConversationID,
					"last_read_message_id":   result.LastReadMessageID,
					"advanced_read_pointer":  result.AdvancedReadPointer,
					"duplicate_read_receipt": result.DuplicateReadReceipt,
				},
			})
		default:
			_ = conn.WriteJSON(map[string]any{"type": "error", "error": "unsupported event"})
		}
	}
}

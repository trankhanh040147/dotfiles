// basic_query: QueryRow, Query, Exec với PostgreSQL.
// Cần: export DATABASE_URL="postgres://user:pass@localhost:5432/dbname?sslmode=disable"
// Chạy: go run basic_query.go
package main

import (
	"database/sql"
	"fmt"
	"os"

	_ "github.com/lib/pq"
)

func main() {
	dsn := os.Getenv("DATABASE_URL")
	if dsn == "" {
		fmt.Println("DATABASE_URL not set")
		return
	}
	db, err := sql.Open("postgres", dsn)
	if err != nil {
		fmt.Println("open:", err)
		return
	}
	defer db.Close()
	if err := db.Ping(); err != nil {
		fmt.Println("ping:", err)
		return
	}

	// QueryRow
	var n int
	if err := db.QueryRow("SELECT 1").Scan(&n); err != nil {
		fmt.Println("queryrow:", err)
		return
	}
	fmt.Println("queryrow result:", n)

	// Query
	rows, err := db.Query("SELECT 1 UNION SELECT 2")
	if err != nil {
		fmt.Println("query:", err)
		return
	}
	defer rows.Close()
	for rows.Next() {
		var v int
		if err := rows.Scan(&v); err != nil {
			break
		}
		fmt.Println("row:", v)
	}

	// Exec (bảng tạm)
	_, err = db.Exec("CREATE TEMP TABLE IF NOT EXISTS demo (id SERIAL PRIMARY KEY, name TEXT)")
	if err != nil {
		fmt.Println("exec create:", err)
		return
	}
	_, err = db.Exec("INSERT INTO demo (name) VALUES ($1)", "alice")
	if err != nil {
		fmt.Println("exec insert:", err)
		return
	}
	fmt.Println("insert ok")
}
